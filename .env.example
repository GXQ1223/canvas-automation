# Canvas LMS
CANVAS_URL=https://canvas.upenn.edu/courses/
CANVAS_USERNAME=your_username
CANVAS_PASSWORD=your_password
CANVAS_COURSE_NAME=CIS 5300 - Spring 2026

# OpenAI (for AI insights + quiz generation)
OPENAI_API_KEY=sk-...

# Homework context for GPT prompts
GPT_QUESTION=Describe your current homework/project here

# Week number to navigate to (e.g., 1, 2, 3, etc.)
WEEK_NUMBER=1

# Chrome persistent session (optional - skips login if already signed in)
# macOS: ~/Library/Application Support/Google/Chrome
# Windows: %LOCALAPPDATA%\Google\Chrome\User Data
# Linux: ~/.config/google-chrome
CHROME_USER_DATA_DIR=~/Library/Application Support/Google/Chrome
CHROME_PROFILE=Default

# Telegram daily report push (optional)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your_chat_id
