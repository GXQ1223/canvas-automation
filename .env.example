# Week number to navigate to (e.g., 1, 2, 3, etc.)
WEEK_NUMBER=1

# Path to Chrome user data directory
# macOS: ~/Library/Application Support/Google/Chrome
# Windows: %LOCALAPPDATA%\Google\Chrome\User Data
# Linux: ~/.config/google-chrome
CHROME_USER_DATA_DIR=~/Library/Application Support/Google/Chrome

# Chrome profile name (usually "Default" or "Profile 1", etc.)
CHROME_PROFILE=Default

# Canvas course URL (your specific course)
CANVAS_COURSE_URL=https://canvas.upenn.edu/courses
